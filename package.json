{
  "name": "ts-printers",
  "type": "module",
  "version": "0.1.0",
  "description": "A TypeScript library and CLI for interacting with printers via IPP (Internet Printing Protocol).",
  "author": "Chris Breuer <chris@stacksjs.org>",
  "license": "MIT",
  "homepage": "https://github.com/stacksjs/ts-printers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stacksjs/ts-printers.git"
  },
  "bugs": {
    "url": "https://github.com/stacksjs/ts-printers/issues"
  },
  "keywords": [
    "typescript",
    "printer",
    "ipp",
    "printing",
    "cups",
    "bonjour",
    "mdns",
    "airprint",
    "hp-tango",
    "bun"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "import": "./dist/*"
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "print": "./dist/bin/cli.js",
    "printers": "./dist/bin/cli.js"
  },
  "files": [
    "README.md",
    "dist"
  ],
  "scripts": {
    "build": "bun --bun build.ts && bun run compile",
    "compile": "bun build ./bin/cli.ts --compile --minify --outfile bin/print",
    "compile:all": "bun run compile:linux-x64 && bun run compile:linux-arm64 && bun run compile:windows-x64 && bun run compile:darwin-x64 && bun run compile:darwin-arm64",
    "compile:linux-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-x64 --outfile bin/print-linux-x64",
    "compile:linux-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-linux-arm64 --outfile bin/print-linux-arm64",
    "compile:windows-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-windows-x64 --outfile bin/print-windows-x64.exe",
    "compile:darwin-x64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-x64 --outfile bin/print-darwin-x64",
    "compile:darwin-arm64": "bun build ./bin/cli.ts --compile --minify --target=bun-darwin-arm64 --outfile bin/print-darwin-arm64",
    "zip": "bun run zip:all",
    "zip:all": "bun run zip:linux-x64 && bun run zip:linux-arm64 && bun run zip:windows-x64 && bun run zip:darwin-x64 && bun run zip:darwin-arm64",
    "zip:linux-x64": "zip -j bin/print-linux-x64.zip bin/print-linux-x64",
    "zip:linux-arm64": "zip -j bin/print-linux-arm64.zip bin/print-linux-arm64",
    "zip:windows-x64": "zip -j bin/print-windows-x64.zip bin/print-windows-x64.exe",
    "zip:darwin-x64": "zip -j bin/print-darwin-x64.zip bin/print-darwin-x64",
    "zip:darwin-arm64": "zip -j bin/print-darwin-arm64.zip bin/print-darwin-arm64",
    "fresh": "bunx rimraf node_modules/ bun.lock && bun i",
    "prepublishOnly": "bun --bun run build && bun run compile:all && bun run zip",
    "test": "bun test",
    "lint": "bunx --bun pickier .",
    "lint:fix": "bunx --bun pickier . --fix",
    "changelog": "bunx logsmith --verbose",
    "changelog:generate": "bunx logsmith --output CHANGELOG.md",
    "release": "bun --bun run changelog:generate && bunx --bun bumpx prompt --recursive",
    "postinstall": "bunx git-hooks",
    "dev:docs": "bun --bun bunpress dev docs",
    "build:docs": "bun --bun bunpress build docs",
    "preview:docs": "bun --bun bunpress preview docs",
    "typecheck": "bun --bun tsc --noEmit",
    "format": "bunx --bun pickier . --format",
    "format:fix": "bunx --bun pickier . --format --write"
  },
  "devDependencies": {
    "better-dx": "^0.2.12"
  },
  "git-hooks": {
    "pre-commit": {
      "stagedLint": {
        "*.{js,ts,json,yaml,yml,md}": "bunx --bun pickier lint --fix"
      },
      "autoRestage": true
    },
    "commit-msg": "bunx gitlint --edit .git/COMMIT_EDITMSG"
  }
}
